# Normalize line endings across platforms so `git status` on Windows stops
# reporting false-positive modifications caused by CRLF/LF drift.
* text=auto eol=lf

# Windows-only script formats keep CRLF.
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Declared binary — never diff, never normalize.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.icns      binary
*.woff      binary
*.woff2     binary
*.ttf       binary
