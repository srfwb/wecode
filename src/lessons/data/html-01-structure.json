{
  "id": "html-01-structure",
  "type": "lesson",
  "title": "HTML Page Structure",
  "description": "Learn the basic tags: html, head, body, title, and paragraph.",
  "difficulty": "beginner",
  "estimatedMinutes": 10,
  "tags": ["html"],
  "allowFileOps": false,
  "starterFiles": {
    "/index.html": "<!DOCTYPE html>\n<html>\n</html>"
  },
  "steps": [
    {
      "heading": "Build the skeleton",
      "paragraphs": [
        {
          "kind": "text",
          "content": "An HTML page is organized into two main parts: the <head> holds invisible information (like the title shown in the tab), and the <body> holds everything the visitor sees. Inside the <head>, add a <title> to name your page. In the <body>, use <h1> for a visible heading and <p> for a paragraph of text."
        },
        {
          "kind": "code",
          "content": "<!DOCTYPE html>\n<html>\n  <head>\n    <title>Ma page</title>\n  </head>\n  <body>\n    <h1>Bonjour !</h1>\n    <p>Voici mon premier paragraphe.</p>\n  </body>\n</html>"
        }
      ],
      "checkpoints": [
        {
          "id": "has-head",
          "label": "Add a `<head>` tag",
          "rule": { "type": "element-exists", "selector": "head", "file": "/index.html" }
        },
        {
          "id": "has-body",
          "label": "Add a `<body>` tag",
          "rule": { "type": "element-exists", "selector": "body", "file": "/index.html" }
        },
        {
          "id": "has-title",
          "label": "Add a `<title>` inside `<head>`",
          "rule": { "type": "nesting", "parent": "head", "child": "title", "file": "/index.html" }
        },
        {
          "id": "has-h1",
          "label": "Add an `<h1>` heading inside `<body>`",
          "rule": { "type": "nesting", "parent": "body", "child": "h1", "file": "/index.html" }
        },
        {
          "id": "has-p",
          "label": "Add a `<p>` paragraph",
          "rule": { "type": "element-exists", "selector": "p", "file": "/index.html" }
        }
      ]
    }
  ]
}
